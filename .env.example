# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=bug-to-user-story-prompt-evaluation

# Para descobrir seu username: publique qualquer prompt no LangSmith Hub,
# depois abra-o e clique no ícone de cadeado (🔒) para ver seu username.
USERNAME_LANGSMITH_HUB=

# Compatibilidade com scripts anteriores (opcional)
LANGSMITH_PROMPT_OWNER=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GOOGLE_API_KEY=

# LLM Configuration (escolha um provider)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EVAL_MODEL=gpt-4o

# Alternativa Gemini (free tier)
#LLM_PROVIDER=google
#LLM_MODEL=gemini-2.5-flash
#EVAL_MODEL=gemini-2.5-flash
